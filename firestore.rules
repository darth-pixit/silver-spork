rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // v1 trust model: anyone with the random household doc id (or the
    // 6-char join code that maps to it) can read/write. Acceptable for
    // private use between trusted family members. Harden later with
    // Firebase App Check if the app gets shared more widely.

    match /households/{hid} {
      allow read, write: if true;

      match /swipes/{swipeId} {
        allow read, write: if true;
      }
    }

    match /joinIndex/{code} {
      allow read, write: if true;
    }
  }
}
